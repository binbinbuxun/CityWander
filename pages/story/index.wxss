.story-page {
  padding-top: 170rpx;
}

.story-hero {
  position: relative;
  padding: 10rpx 40rpx 54rpx;
}

.story-hero .bookmark-button {
  position: absolute;
  right: 40rpx;
  top: 0;
}

.story-hero__kicker {
  display: block;
  font-size: 24rpx;
  color: #8e8e93;
  letter-spacing: 6rpx;
}

.story-hero__title {
  display: block;
  margin-top: 20rpx;
  font-size: 72rpx;
  line-height: 1.06;
  color: #2a2a2a;
}

.story-hero__subtitle {
  display: block;
  margin-top: 22rpx;
  width: 76%;
  font-size: 32rpx;
  line-height: 1.95;
  color: #6b6b6b;
  letter-spacing: 2rpx;
}

.story-cover {
  width: 100%;
  height: 760rpx;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 46rpx rgba(0, 0, 0, 0.08);
}

.story-excerpt {
  display: block;
  margin: 34rpx 10rpx 0;
  font-size: 34rpx;
  line-height: 1.95;
  color: #4a4a4a;
  letter-spacing: 2rpx;
}

.story-gallery {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 42rpx;
  padding: 0 4rpx;
}

.story-gallery__image {
  width: 100%;
  height: 280rpx;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.story-gallery__image:nth-child(3) {
  grid-column: span 2;
  height: 340rpx;
}

.story-article {
  padding: 52rpx 10rpx 8rpx;
}

.story-article__paragraph {
  display: block;
  margin-bottom: 34rpx;
  font-size: 32rpx;
  line-height: 2;
}

.story-expanded {
  padding: 20rpx 10rpx 40rpx;
}

.story-section {
  margin-bottom: 44rpx;
  padding-top: 28rpx;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.story-section__heading {
  display: block;
  font-size: 40rpx;
  color: #2a2a2a;
  margin-bottom: 22rpx;
  line-height: 1.3;
}

.story-section__body {
  display: block;
  font-size: 32rpx;
  line-height: 2.05;
}
