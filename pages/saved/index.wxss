.saved-page {
  padding-top: 150rpx;
}

.saved-hero {
  padding: 10rpx 40rpx 36rpx;
}

.saved-hero__title {
  display: block;
  margin-top: 0;
  font-size: 72rpx;
  color: #2a2a2a;
}

.saved-hero__subtitle {
  display: block;
  margin-top: 22rpx;
  width: 78%;
  font-size: 28rpx;
  line-height: 1.9;
  color: #666666;
  letter-spacing: 2rpx;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  margin-bottom: 30rpx;
}

.user-card__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.user-card__info {
  flex: 1;
  padding-left: 22rpx;
}

.user-card__name {
  display: block;
  font-size: 30rpx;
  color: #2a2a2a;
  font-weight: 500;
}

.user-card__hint {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8e8e93;
}

.user-card__logout {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.12);
}

.user-card__logout-text {
  font-size: 22rpx;
  color: #8e8e93;
  letter-spacing: 2rpx;
}

.saved-login {
  padding: 40rpx 32rpx;
}

.saved-login__title {
  display: block;
  font-size: 46rpx;
  color: #2a2a2a;
}

.saved-login__copy {
  display: block;
  margin-top: 18rpx;
}

.saved-login__button {
  margin-top: 30rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(32, 32, 32, 0.85);
  backdrop-filter: saturate(180%) blur(16px);
  -webkit-backdrop-filter: saturate(180%) blur(16px);
  border: 0.5px solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 88rpx;
}

/* 重置 button 默认样式 */
.saved-login__button::after {
  border: none;
}

.saved-login__button-text {
  font-size: 28rpx;
  color: #f9f8f6;
  letter-spacing: 4rpx;
}

.saved-login__note {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: #b0b0b0;
  letter-spacing: 1rpx;
}

.saved-empty {
  min-height: 56vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 36rpx;
}

.saved-section {
  margin-bottom: 38rpx;
}

.saved-section__title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 42rpx;
  color: #2a2a2a;
}

.saved-card {
  overflow: hidden;
  margin-bottom: 22rpx;
}

.saved-card__image {
  width: 100%;
  height: 300rpx;
}

.saved-card__body {
  padding: 24rpx 26rpx 28rpx;
}

.saved-card__city {
  display: block;
  font-size: 18rpx;
  color: #8e8e93;
}

.saved-card__title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  color: #2a2a2a;
}

.saved-card__summary {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #666666;
}
