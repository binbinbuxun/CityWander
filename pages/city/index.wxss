.city-page {
  padding-bottom: 100rpx;
}
.city-hero {
  position: relative;
  height: 60vh;
  min-height: 760rpx;
  overflow: hidden;
}
.city-hero__swiper {
  width: 100%;
  height: 100%;
}
.city-hero__image {
  width: 100%;
  height: 100%;
}
.city-hero__veil {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(10, 10, 10, 0.16), rgba(10, 10, 10, 0.5));
}
.city-hero__copy {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 58rpx;
}
.city-hero__cn {
  display: block;
  font-size: 70rpx;
  color: rgba(249, 248, 246, 0.96);
}
.city-hero__en {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.2;
  color: rgba(249, 248, 246, 0.76);
  letter-spacing: 8rpx;
}
.city-hero__slogan {
  display: block;
  margin-top: 26rpx;
  width: 72%;
  font-size: 26rpx;
  line-height: 1.9;
  color: rgba(249, 248, 246, 0.78);
}
.city-body {
  margin-top: -70rpx;
  padding: 0 28rpx;
}
.city-intro {
  padding: 34rpx 30rpx;
}
.city-intro__title {
  display: block;
  margin-top: 16rpx;
  font-size: 46rpx;
  color: #2a2a2a;
}
.city-intro__copy {
  display: block;
  margin-top: 18rpx;
  font-size: 32rpx;
}
.city-intro__coords {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #8e8e93;
  letter-spacing: 2rpx;
}
.topic-list {
  margin-top: 42rpx;
}
.topic-card {
  position: relative;
  height: 420rpx;
  width: 100%;
  margin-bottom: 28rpx;
  overflow: hidden;
  margin-left: auto;
  margin-right: auto;
}
.topic-card__image {
  width: 100%;
  height: 100%;
}
.topic-card__veil {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(14, 14, 14, 0.08), rgba(14, 14, 14, 0.48));
}
.topic-card__body {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  bottom: 30rpx;
  text-align: left;
}
.topic-card__serial {
  display: block;
  font-size: 22rpx;
  color: rgba(249, 248, 246, 0.72);
  letter-spacing: 4rpx;
}
.topic-card__english {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: rgba(249, 248, 246, 0.7);
}
.topic-card__title {
  display: block;
  margin-top: 14rpx;
  font-size: 50rpx;
  color: #f9f8f6;
}
.topic-card__blurb {
  display: block;
  margin-top: 14rpx;
  width: 100%;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(249, 248, 246, 0.84);
}
